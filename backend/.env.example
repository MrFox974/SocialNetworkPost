# Aligné avec docker-compose.yml (Postgres local)
DATABASE_NAME=social-network-db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

PORT=8080
HOST=localhost

# ─── Réseau / CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# Auth : false = login simple (email + mdp local), true = vérification email + Google
PRODUCTION=false

# ─── JWT (obligatoires pour login, refresh, routes protégédzqdqzes) ──────────
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── OAuth Google (connexion / inscription avec Google) ─────────────────
# Console : https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# ─── OAuth Apple (connexion / inscription avec Apple) ───────────────────
# https://developer.apple.com
APPLE_CLIENT_ID=

# ─── Email SMTP (envoi : vérification d'adresse, bienvenue) ─────────────
# Par défaut Gandi : mail.gandi.net, port 587.
SMTP_HOST=mail.gandi.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Format : "Nom affiché" <email@domain.com>
SMTP_FROM=
# URL du frontend pour les liens dans les emails (ex. vérification)
FRONTEND_URL=http://localhost:5173

# ─── Optionnel : notifications ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Stripe (si tu actives les paiements)
STRIPE_SECRET_KEY=

# IDs produit Stripe (Dashboard Stripe) - un par plan (abonnements mensuels)
# Exemple : prod_ABC123...
STRIPE_PRODUCT_MAITRISE=
STRIPE_PRODUCT_PERFORMANCE=

# SpeechForge
OPENAI_API_KEY=
# Optionnel : secret JWT Supabase (Project Settings > API > JWT Secret) pour vérifier les tokens
SUPABASE_JWT_SECRET=